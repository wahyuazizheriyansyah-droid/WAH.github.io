let lang = "en";

function updateLanguage() {
    // Mencari semua elemen yang memiliki atribut data-en
    document.querySelectorAll("[data-en]").forEach(el => {
        const newText = el.getAttribute(`data-${lang}`);
        if (newText) {
            el.innerText = newText;
        }
    });
}

function toggleLang() {
    lang = (lang === "en") ? "id" : "en";
    updateLanguage();
}

// Menjalankan fungsi update bahasa pertama kali saat halaman dimuat (agar nama tidak kosong)
window.onload = () => {
    updateLanguage();
};

