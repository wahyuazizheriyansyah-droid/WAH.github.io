function changeLanguage() {
    // Mengambil nilai bahasa dari menu dropdown
    const lang = document.getElementById("langSelector").value;
    
    // Menerapkan terjemahan ke semua teks yang memiliki atribut data-[bahasa]
    document.querySelectorAll("[data-en]").forEach(el => {
        const newText = el.getAttribute(`data-${lang}`);
        if (newText) {
            el.innerText = newText;
        }
    });
}

// Menjalankan fungsi saat halaman pertama kali dimuat agar tidak kosong
window.onload = () => {
    changeLanguage();
};

