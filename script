let lang = "en";

function toggleLang() {
    lang = (lang === "en") ? "id" : "en";

    document.querySelectorAll("[data-en]").forEach(el => {
        el.innerText = el.getAttribute(`data-${lang}`);
    });
}

/* Modal content */
const data = {
    fft: {
        en: "FFT analysis using MATLAB to analyze signal frequency spectrum.",
        id: "Analisis FFT menggunakan MATLAB untuk spektrum frekuensi sinyal."
    },
    solar: {
        en: "Analyzing solar panel efficiency based on light and humidity.",
        id: "Analisis efisiensi panel surya berdasarkan cahaya dan kelembaban."
    },
    drone: {
        en: "Design and development of hexacopter drone system.",
        id: "Desain dan pengembangan drone hexacopter."
    }
};

function openModal(key) {
    document.getElementById("modal").style.display = "block";
    document.getElementById("modal-body").innerText = data[key][lang];
}

function closeModal() {
    document.getElementById("modal").style.display = "none";
}